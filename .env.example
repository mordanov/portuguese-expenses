# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=portuguese_expenses

# asyncpg connection URL — must match the credentials above
DATABASE_URL=postgresql+asyncpg://postgres:changeme@db:5432/portuguese_expenses

# ============================================================
# JWT (RS256)
# Generate a key pair with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Collapse newlines to \n literals before pasting:
#   awk 'NR==1{printf "%s",$0;next}{printf "\\n%s",$0}END{print ""}' private.pem
# ============================================================
# Note: OpenSSL 3.x genrsa outputs PKCS#8 format (BEGIN PRIVATE KEY), which
# python-jose accepts for RS256. Do not attempt PKCS#1 conversion.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=480

# ============================================================
# Pre-seeded application users (created by Alembic migration 003)
# Passwords are bcrypt-hashed before storage — plain text never persisted.
# ============================================================
APP_USER_1_USERNAME=admin
APP_USER_1_PASSWORD=changeme
APP_USER_2_USERNAME=editor
APP_USER_2_PASSWORD=changeme

# ============================================================
# OpenAI (gpt-4o vision for OCR)
# ============================================================
OPENAI_API_KEY=sk-...

# ============================================================
# File uploads
# ============================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20
MAX_TOTAL_UPLOAD_SIZE_MB=200

# ============================================================
# CORS — locked to the frontend origin; no wildcards
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# Frontend (baked into the React bundle at build time)
# ============================================================
VITE_API_BASE_URL=http://localhost:8000
